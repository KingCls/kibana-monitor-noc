def _confirmados_path():
    """Caminho do arquivo de erros confirmados do dia atual."""
    CACHE_DIR.mkdir(exist_ok=True)
    hoje = datetime.now().strftime("%Y-%m-%d")
    return CACHE_DIR / f"confirmados_{hoje}.json"


def carregar_erros_confirmados():
    """Carrega hashes de erros confirmados do arquivo do dia."""
    global erros_confirmados
    caminho = _confirmados_path()
    if caminho.exists():
        try:
            with open(caminho, "r", encoding="utf-8") as f:
                dados = json.load(f)
            with erros_confirmados_lock:
                erros_confirmados = set(dados if isinstance(dados, list) else [])
            log(f"Confirmados carregados: {len(erros_confirmados)} hash(es)", "INFO")
        except Exception as e:
            log(f"Erro ao carregar confirmados: {e}", "AVISO")
    else:
        with erros_confirmados_lock:
            erros_confirmados = set()


def salvar_erros_confirmados():
    """Persiste hashes de erros confirmados no arquivo do dia."""
    caminho = _confirmados_path()
    try:
        with erros_confirmados_lock:
            lista = list(erros_confirmados)
        with open(caminho, "w", encoding="utf-8") as f:
            json.dump(lista, f)
    except Exception as e:
        log(f"Erro ao salvar confirmados: {e}", "AVISO")


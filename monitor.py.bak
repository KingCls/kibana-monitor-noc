# Funcoes utilitarias

def log(msg, nivel="INFO"):
    """Imprime log no terminal com timestamp."""
    timestamp = datetime.now().strftime("%H:%M:%S")
    cores = {
        "INFO": "\033[37m",     # branco
        "OK": "\033[32m",       # verde
        "AVISO": "\033[33m",    # amarelo
        "ERRO": "\033[31m",     # vermelho
        "NOVO": "\033[35m",     # magenta
    }
    cor = cores.get(nivel, "\033[37m")
    reset = "\033[0m"
    print(f"  {cor}[{timestamp}] [{nivel:5s}] {msg}{reset}")


def log_arquivo(msg):
    """Salva log em arquivo do dia."""
    LOG_DIR.mkdir(exist_ok=True)
    hoje = datetime.now().strftime("%Y-%m-%d")
    log_file = LOG_DIR / f"log_{hoje}.txt"
    timestamp = datetime.now().strftime("%Y-%m-%d %H:%M:%S")
    with open(log_file, "a", encoding="utf-8") as f:
        f.write(f"{timestamp} - {msg}\n")


def adicionar_dias_uteis(data_base, quantidade):
    """Soma dias uteis, pulando sabado e domingo."""
    data_atual = data_base
    dias_adicionados = 0

    while dias_adicionados < quantidade:
        data_atual += timedelta(days=1)
        if data_atual.weekday() < 5:
            dias_adicionados += 1

    return data_atual


def atualizar_datas_relatorio(data_base=None):
    """Atualiza as datas do relatorio textual conforme o dia atual."""
    if not RELATORIO_PATH.exists():
        return

    if data_base is None:
        data_base = datetime.now().date()

    proximo_dia = adicionar_dias_uteis(data_base, 1)
    dia_seguinte = adicionar_dias_uteis(data_base, 2)

    try:
        with open(RELATORIO_PATH, "r", encoding="utf-8") as f:
            conteudo_atual = f.read()

        conteudo_novo = re.sub(
            r"CHECK-LIST FECHAMENTO DO DIA \d{2}/\d{2}/\d{4}",
            f"CHECK-LIST FECHAMENTO DO DIA {data_base.strftime('%d/%m/%Y')}",
            conteudo_atual,
            count=1,
        )
        conteudo_novo = re.sub(
            r"tb_exchange - dia \d{2}/\d{2}/\d{2}",
            f"tb_exchange - dia {proximo_dia.strftime('%d/%m/%y')}",
            conteudo_novo,
        )
        conteudo_novo = re.sub(
            r"tb_exchange - dia Seguinte \d{2}/\d{2}/\d{2}",
            f"tb_exchange - dia Seguinte {dia_seguinte.strftime('%d/%m/%y')}",
            conteudo_novo,
        )

        if conteudo_novo != conteudo_atual:
            with open(RELATORIO_PATH, "w", encoding="utf-8") as f:
                f.write(conteudo_novo)
            log(
                "Datas do relatorio atualizadas para o novo dia util.",
                "INFO",
            )
    except Exception as e:
        log(f"Erro ao atualizar relatorio: {e}", "AVISO")


def carregar_config():
    """Carrega e valida o arquivo config.json."""
    if not CONFIG_PATH.exists():
        log(f"Arquivo config.json nao encontrado em: {CONFIG_PATH}", "ERRO")
        return None

    try:
        with open(CONFIG_PATH, "r", encoding="utf-8") as f:
            texto = f.read()
        config = json.loads(texto)

        # Validacoes basicas
        if not config.get("kibana_url"):
            log("ERRO: 'kibana_url' nao configurada no config.json", "ERRO")
            return None
        if "links" not in config or not isinstance(config.get("links"), list):
            config["links"] = []

        ativas = sum(1 for c in config.get("links", []) if c.get("ativo", True))
        log(f"Configuracao carregada: {ativas} link(s) ativo(s)", "OK")
        return config
    except Exception as e:
        log(f"Erro ao ler config.json: {e}", "ERRO")
        return None


def salvar_config(config):
    """Salva configuracao no config.json."""
    try:
        with open(CONFIG_PATH, "w", encoding="utf-8") as f:
            json.dump(config, f, ensure_ascii=False, indent=4)
        return True, None
    except Exception as e:
        return False, str(e)



def obter_config_snapshot():
    """Retorna uma copia da configuracao atual em memoria."""
    with config_lock:
        if runtime_config is None:
            return None
        return json.loads(json.dumps(runtime_config))


def atualizar_config_runtime(nova_config):
    """Atualiza configuracao em memoria e persiste em arquivo."""
    global runtime_config
    ok, erro = salvar_config(nova_config)
    if not ok:
        return False, erro
    with config_lock:
        runtime_config = nova_config
    return True, None


# Historico de erros

def caminho_historico():
    """Retorna o caminho do historico do dia atual."""
    HISTORICO_DIR.mkdir(exist_ok=True)
    hoje = datetime.now().strftime("%Y-%m-%d")
    return HISTORICO_DIR / f"erros_{hoje}.json"


def carregar_historico():
    """Carrega historico de erros do dia. Se novo dia, retorna vazio."""
    global historico_dia, historico_palavras
    caminho = caminho_historico()

    if caminho.exists():
        try:
            with open(caminho, "r", encoding="utf-8") as f:
                conteudo = f.read().strip()
            if conteudo:
                historico_dia = json.loads(conteudo)
            else:
                historico_dia = {}
        except Exception as e:
            log(f"Erro ao carregar historico, criando novo: {e}", "AVISO")
            historico_dia = {}
    else:
        log("Novo dia detectado! Historico resetado.", "INFO")
        historico_dia = {}

    # Reconstroi o indice de palavras para deduplicacao
    rebuilt = {}
    for entry in historico_dia.values():
        lnk = entry.get("link", "")
        palavras = extrair_palavras(entry.get("mensagem", ""))
        if palavras:
            if lnk not in rebuilt:
                rebuilt[lnk] = []
            rebuilt[lnk].append(palavras)
    historico_palavras = rebuilt
    log(f"Historico carregado: {len(historico_dia)} erro(s), {sum(len(v) for v in rebuilt.values())} conjunto(s) de palavras indexados.", "INFO")

    return historico_dia


def salvar_historico():
    """Salva historico de erros do dia em JSON."""
    caminho = caminho_historico()
    try:
        with open(caminho, "w", encoding="utf-8") as f:
            json.dump(historico_dia, f, ensure_ascii=False, indent=2)
    except Exception as e:
        log(f"Erro ao salvar historico: {e}", "ERRO")


def limpar_historicos_antigos():
    """Remove historicos e logs com mais de 7 dias."""
    limite = datetime.now() - timedelta(days=7)

    for pasta in [HISTORICO_DIR, LOG_DIR, CACHE_DIR]:
        if not pasta.exists():
            continue
        for arquivo in pasta.iterdir():
            if arquivo.is_file():
                try:
                    mod_time = datetime.fromtimestamp(arquivo.stat().st_mtime)
                    if mod_time < limite:
                        arquivo.unlink()
                        log(f"Arquivo antigo removido: {arquivo.name}", "INFO")
                except Exception:
                    pass


